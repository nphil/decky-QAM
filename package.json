{
  "name": "decky-qam",
  "version": "1.0.0",
  "description": "Remap the Quick Access Menu to a back button (L4/L5/R4/R5) for Steam Decks with a broken QAM hardware button.",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c",
    "watch": "rollup -c -w"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "deck",
    "qam",
    "remap",
    "input"
  ],
  "author": "nphil",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/rollup": "^1.0.1",
    "@decky/ui": "^4.7.1",
    "@types/react": "18.3.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.21.2",
    "shx": "^0.3.4",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@decky/api": "^1.1.2",
    "react-icons": "^5.3.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
